alias v="nvim"
alias lzg="lazygit"
alias lzd="lazydocker"
alias lzs="lazysql"
alias ..="cd .."

# Android/Emulator
alias emu="emulator -list-avds"
alias emu-run="emulator -avd NvimEmulator"

alias hbn='sudo systemctl hibernate'      # Ngủ đông (lưu vào swap 31GB của bạn)
alias sup='systemctl suspend'              # Tạm dừng (ngủ nhẹ)
alias reb='sudo reboot'                    # Khởi động lại
alias off='sudo poweroff'                 # Tắt máy hoàn toàn
alias out='gnome-session-quit --logout' # Đăng xuất nhanh
alias lock='loginctl lock-session'  # Khóa màn hình
